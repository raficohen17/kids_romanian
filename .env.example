# Local development env reference. Copy to `.env` and fill in.
# The real .env is gitignored.

# ----- Frontend (read by build-config.js, exposed to the browser) -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ----- Backend / Vercel function (server-side only) -----
# Required for /api/chat to call OpenRouter. The function accepts any of these
# names (in priority order): OPEN_ROUTER_API_KEY, OPEN_ROUTER, OPENROUTER_API_KEY.
OPEN_ROUTER_API_KEY=sk-or-v1-...

# Optional model override. Default: anthropic/claude-haiku-4-5
# Either OPEN_ROUTER_MODEL or OPENROUTER_MODEL works.
# OPEN_ROUTER_MODEL=anthropic/claude-haiku-4-5

# Optional daily message cap per profile. Default: 60
# CHAT_DAILY_LIMIT=60

# Also needed server-side (function reads either name):
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
